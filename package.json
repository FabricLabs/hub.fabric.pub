{
  "name": "@fabric/hub",
  "version": "0.1.0-RC1",
  "description": "Peer rendezvous for Fabric.",
  "main": "services/hub.js",
  "exports": {
    ".": "./services/hub.js",
    "./components/HubInterface": "./components/HubInterface.js",
    "./components/DelegationSigningModal": "./components/DelegationSigningModal.js",
    "./components/SettingsHome": "./components/SettingsHome.js",
    "./functions/fabricMessageEnvelope": "./functions/fabricMessageEnvelope.js",
    "./functions/fabricProtocolUrl": "./functions/fabricProtocolUrl.js",
    "./components/SecuritySessionHome": "./components/SecuritySessionHome.js",
    "./types/LightningChannel": "./types/lightningChannel.js"
  },
  "engines": {
    "node": "22.14.0"
  },
  "scripts": {
    "build": "npm run build:browser",
    "build:browser": "node scripts/build.js",
    "build:desktop": "npm run build:browser && electron-builder build",
    "build:desktop:dir": "npm run build:browser && electron-builder --dir",
    "link:fabric": "bash scripts/link-fabric.sh",
    "predesktop": "node scripts/ensure-fabric-linked.js",
    "desktop": "npm run build:browser && electron electron/main.js",
    "build:extension": "node scripts/build-extension.js",
    "build:semantic": "cd libraries/semantic && npx gulp build && cd ../..",
    "ci": "npm run build && npm run test:unit",
    "coverage": "c8 npm test",
    "dev": "webpack serve --mode development --open",
    "make:api": "jsdoc2md --configure jsdoc.json --files services/hub.js README.md > API.md",
    "make:app": "node scripts/build.js",
    "make:browser": "npm run build:browser",
    "make:coverage": "npm run coverage && c8 report --reporter html",
    "make:fonts": "node scripts/download-fonts.js",
    "reports": "npm run report:install && npm run report:coverage",
    "report:coverage": "npm run make:coverage && c8 report --reporter=text-lcov > reports/coverage.lcov",
    "report:install": "rm -rf node_modules && echo \"\n\" > package-lock.json && echo \"$ npm i\" > reports/install.log && npm i >> reports/install.log",
    "report:legal": "node_modules/.bin/license-checker --json > reports/licenses.json",
    "report:todo": "grep --exclude package.json --exclude-dir=.env --exclude-dir=.git --exclude-dir=_book --exclude-dir=stores --exclude-dir=assets --exclude-dir=node_modules --exclude-dir=reports --exclude-dir=coverage --exclude-dir=docs --exclude-dir=libraries -rEI \"TODO|FIXME\" . | sed 's/\\([^:]*:\\)[ ]*/\\1 /' > reports/TODO.txt",
    "review:coverage": "npm run make:coverage && http-server -p 8000 reports/coverage",
    "start": "npm run build && node scripts/hub.js",
    "start:fast": "node scripts/hub.js",
    "sync": "npm run sync:specs",
    "sync:specs": "scripts/import-specs.sh",
    "test": "mocha tests --exit",
    "test:unit": "mocha tests --exit --ignore tests/browser.interface.test.js",
    "test:bridge": "mocha tests/bridge.webrtc.signal.test.js",
    "test:browser": "mocha tests/browser.interface.test.js --exit --timeout 60000",
    "test:e2e-browser": "HUB_E2E=1 mocha tests/browser.interface.test.js --exit --timeout 90000",
    "test:e2e-payjoin": "node scripts/verify-payjoin-e2e.js",
    "test:lightning": "mocha tests/lightning.hub.http.test.js tests/lightning.bitcoinClient.test.js --exit",
    "test:smoke-mainnet-rpc": "node scripts/verify-mainnet-rpc-smoke.js",
    "bitcoin:addnode": "node scripts/bitcoin-addnode.js",
    "test:e2e-webrtc": "node scripts/verify-webrtc-chat-e2e.js",
    "test:hub-webrtc": "mocha tests/hub.webrtc.rpc.test.js",
    "test:webrtc": "npm run test:bridge && npm run test:hub-webrtc",
    "todo": "npm run report:todo && cat reports/TODO.txt"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FabricLabs/hub.fabric.pub.git"
  },
  "keywords": [
    "fabric",
    "p2p",
    "bitcoin",
    "blockchain",
    "sidechain"
  ],
  "author": "Fabric Labs",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/FabricLabs/hub.fabric.pub/issues"
  },
  "homepage": "https://github.com/FabricLabs/hub.fabric.pub#readme",
  "dependencies": {
    "@fabric/core": "FabricLabs/fabric#feature/cli-refresh",
    "@babel/preset-env": "=7.26.7",
    "@babel/preset-react": "=7.26.3",
    "@babel/register": "=7.25.9",
    "@fabric/http": "FabricLabs/fabric-http#feature/v0.1.0-RC1",
    "@noble/curves": "=1.6.0",
    "@noble/hashes": "=1.5.0",
    "@types/react": "=18.3.18",
    "bs58check": "=3.0.1",
    "cross-fetch": "=4.1.0",
    "fast-json-patch": "=3.1.1",
    "html5-qrcode": "=2.3.8",
    "jquery": "=3.7.1",
    "jsdoc-to-markdown": "=8.0.0",
    "jsdom": "=28.1.0",
    "lodash.merge": "=4.6.2",
    "mocha": "=10.8.2",
    "path-browserify": "=1.0.1",
    "process": "=0.11.10",
    "qrcode": "=1.5.4",
    "react": "=18.2.0",
    "react-dom": "=18.2.0",
    "react-redux": "=8.1.0",
    "react-router-dom": "=6.30.3",
    "react-simple-star-rating": "=5.1.7",
    "react-textarea-autosize": "=8.5.7",
    "react-toastify": "=10.0.5",
    "redux": "=4.2.1",
    "redux-thunk": "=2.4.2",
    "semantic-ui-react": "=2.1.5",
    "stream-browserify": "=3.0.0",
    "webpack": "=5.105.4"
  },
  "devDependencies": {
    "babel-loader": "=9.1.3",
    "browserify-fs": "=1.0.0",
    "buffer": "=6.0.3",
    "c8": "=7.11.3",
    "crypto-browserify": "=3.12.1",
    "css-loader": "=6.10.0",
    "electron": "^36.3.2",
    "electron-builder": "^24.13.3",
    "style-loader": "=3.3.4",
    "vm-browserify": "=1.1.2",
    "webpack-bundle-analyzer": "=4.10.2",
    "webpack-cli": "=5.1.4",
    "webpack-dev-server": "=5.2.2"
  },
  "c8": {
    "exclude": [
      "assets",
      "tests",
      "stores"
    ],
    "report-dir": "./reports/coverage",
    "temp-dir": "./reports/c8"
  },
  "build": {
    "appId": "pub.fabric.hub",
    "productName": "Fabric Hub",
    "copyright": "Copyright © Fabric Labs",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "assets/**/*",
      "scripts/hub.js",
      "services/**/*",
      "functions/**/*",
      "types/**/*",
      "routes/**/*",
      "settings/**/*",
      "shims/**/*",
      "package.json",
      "node_modules/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!stores/**",
      "!tests/**",
      "!docs/**",
      "!coverage/**",
      "!reports/**",
      "!extension/**",
      "!libraries/**"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "protocols": [
      {
        "name": "Fabric Hub",
        "schemes": [
          "fabric"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
