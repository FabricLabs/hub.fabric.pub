{
  "name": "@fabric/hub",
  "version": "0.1.0-RC1",
  "description": "Peer rendezvous for Fabric.",
  "main": "services/hub.js",
  "exports": {
    ".": "./services/hub.js",
    "./components/ActivityStream": "./components/ActivityStream.js",
    "./components/Bridge": "./components/Bridge.js",
    "./components/HubInterface": "./components/HubInterface.js",
    "./components/DelegationSigningModal": "./components/DelegationSigningModal.js",
    "./components/SettingsHome": "./components/SettingsHome.js",
    "./functions/fabricMessageEnvelope": "./functions/fabricMessageEnvelope.js",
    "./functions/fabricDocumentOfferEnvelope": "./functions/fabricDocumentOfferEnvelope.js",
    "./functions/fabricProtocolUrl": "./functions/fabricProtocolUrl.js",
    "./components/SecuritySessionHome": "./components/SecuritySessionHome.js",
    "./types/LightningChannel": "./types/lightningChannel.js"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "npm run build:browser",
    "build:browser": "node scripts/build.js",
    "build:desktop": "npm run build:browser && electron-builder build",
    "build:desktop:dir": "npm run build:browser && electron-builder --dir",
    "link:fabric": "bash scripts/link-fabric.sh",
    "predesktop": "node scripts/ensure-fabric-linked.js && node scripts/prepare-hub-dev-port.js",
    "desktop": "npm run build:browser && env -u ELECTRON_RUN_AS_NODE ./node_modules/.bin/electron scripts/desktop.js",
    "desktop:debug": "npm run build:browser && env -u ELECTRON_RUN_AS_NODE ./node_modules/.bin/electron --inspect=9229 scripts/desktop.js",
    "build:extension": "node scripts/build-extension.js",
    "ci": "npm run build && npm run test:unit",
    "coverage": "c8 npm test",
    "build:semantic": "node scripts/build-semantic-assets.js",
    "make:fonts": "npm run make:fonts --prefix ./node_modules/@fabric/http",
    "dev": "webpack serve --mode development --open",
    "make:api": "jsdoc2md --configure jsdoc.json --files services/hub.js README.md > API.md",
    "make:app": "node scripts/build.js",
    "make:browser": "npm run build:browser",
    "make:coverage": "npm run coverage && c8 report --reporter html",
    "reports": "npm run report:install && npm run report:coverage",
    "report:coverage": "npm run make:coverage && c8 report --reporter=text-lcov > reports/coverage.lcov",
    "report:install": "rm -rf node_modules && echo \"\n\" > package-lock.json && echo \"$ npm i\" > reports/install.log && npm i >> reports/install.log",
    "report:legal": "node_modules/.bin/license-checker --json > reports/licenses.json",
    "report:dependency-trees": "node scripts/generate-dependency-trees.js",
    "report:todo": "grep --exclude package.json --exclude-dir=.env --exclude-dir=.git --exclude-dir=_book --exclude-dir=stores --exclude-dir=assets --exclude-dir=node_modules --exclude-dir=reports --exclude-dir=coverage --exclude-dir=docs --exclude-dir=libraries -rEI \"TODO|FIXME\" . | sed 's/\\([^:]*:\\)[ ]*/\\1 /' > reports/TODO.txt",
    "review:coverage": "npm run make:coverage && http-server -p 8000 reports/coverage",
    "prestart": "node scripts/prepare-hub-dev-port.js",
    "start": "npm run build && node scripts/hub.js",
    "start:fast": "node scripts/prepare-hub-dev-port.js && node scripts/hub.js",
    "hub-ui:test-secrets": "node scripts/hub-ui-write-test-secrets.js",
    "hub-ui:test-secrets:inject": "node scripts/hub-ui-write-test-secrets.js --print-inject",
    "cursor-agent:init": "node scripts/cursor-agent-fabric-identity.js init",
    "cursor-agent:emit-hub-config": "node scripts/cursor-agent-fabric-identity.js emit-hub-config",
    "cursor-agent:print-env": "node scripts/cursor-agent-fabric-identity.js print-shell-export",
    "cursor-agent:sync-sensemaker": "node scripts/cursor-agent-sync-sensemaker.js",
    "start:mainnet-local": "bash scripts/run-hub-local-mainnet.sh",
    "sync": "npm run sync:specs",
    "sync:specs": "scripts/import-specs.sh",
    "test": "mocha tests --exit --ignore tests/browser.hubAlerts.test.js --ignore tests/browser.onboardingPeers.e2e.test.js",
    "test:unit": "mocha tests --exit --ignore tests/browser.interface.test.js --ignore tests/browser.hubAlerts.test.js --ignore tests/browser.onboardingPeers.e2e.test.js --ignore tests/crowdfunding.regtest.integration.js",
    "test:bridge": "mocha tests/bridge.webrtc.signal.test.js",
    "puppeteer:install-chrome": "npx puppeteer browsers install chrome",
    "test:browser": "npm run build:browser && mocha tests/browser.interface.test.js --exit --timeout 60000",
    "test:e2e-browser": "npm run build:browser && HUB_E2E=1 mocha tests/browser.interface.test.js --exit --timeout 90000",
    "test:e2e-browser-onboarding": "npm run build:browser && HUB_E2E_UI_ONBOARDING=1 mocha tests/browser.onboardingPeers.e2e.test.js --exit --timeout 120000",
    "test:e2e-hub-alerts": "mocha tests/browser.hubAlerts.test.js --exit --timeout 120000",
    "test:e2e-payjoin": "node scripts/verify-payjoin-e2e.js",
    "test:e2e-all-browser": "node scripts/verify-browser-e2e-suite.js",
    "test:stack": "node scripts/verify-full-stack.js",
    "test:stack:no-l1": "FABRIC_STACK_SKIP_L1_CONTRACTS=1 node scripts/verify-full-stack.js",
    "ci:e2e-payjoin": "bash scripts/ci-e2e-payjoin.sh",
    "test:crowdfund-regtest": "FABRIC_CROWDFUND_REGTEST=1 mocha tests/crowdfunding.regtest.integration.js --exit --timeout 600000",
    "test:e2e-storage-contract": "node scripts/verify-storage-contract-e2e.js",
    "test:e2e-document-purchase": "node scripts/verify-document-purchase-e2e.js",
    "test:e2e-execution-contract": "node scripts/verify-execution-contract-e2e.js",
    "test:e2e-execution-anchor": "FABRIC_EXEC_E2E_ANCHOR=1 node scripts/verify-execution-contract-e2e.js",
    "test:e2e-crowdfund-l1": "node scripts/verify-crowdfund-l1-e2e.js",
    "test:e2e-value-flows": "node scripts/verify-value-flows-e2e.js",
    "test:e2e-contracts-l1": "node scripts/verify-contracts-l1-e2e-suite.js",
    "test:lightning": "mocha tests/lightning.hub.http.test.js tests/lightning.bitcoinClient.test.js --exit",
    "test:smoke-mainnet-rpc": "node scripts/verify-mainnet-rpc-smoke.js",
    "bitcoin:addnode": "node scripts/bitcoin-addnode.js",
    "test:playnet-mesh": "FABRIC_PLAYNET_MESH=1 mocha tests/playnet.market.integration.js --exit --timeout 600000",
    "test:playnet-mesh-l1": "FABRIC_BITCOIN_SKIP_PLAYNET_PEER=1 FABRIC_PLAYNET_MESH_L1=1 mocha tests/playnet.market.integration.js --exit --timeout 600000",
    "test:playnet-mesh-l1-chain-deep": "FABRIC_BITCOIN_SKIP_PLAYNET_PEER=1 FABRIC_PLAYNET_MESH_L1=1 FABRIC_PLAYNET_BROWSER_DEEP_TX=1 FABRIC_PLAYNET_BROWSER_DEEP_BLOCK=1 mocha tests/playnet.market.integration.js --exit --timeout 600000",
    "test:playnet-mesh-l1-browser-deep": "npm run test:playnet-mesh-l1-chain-deep",
    "test:playnet-mesh-l1-desktop-star": "FABRIC_BITCOIN_SKIP_PLAYNET_PEER=1 FABRIC_PLAYNET_MESH_L1=1 FABRIC_PLAYNET_DESKTOP_STAR=1 FABRIC_PLAYNET_BROWSER_DEEP_TX=1 FABRIC_PLAYNET_BROWSER_DEEP_BLOCK=1 mocha tests/playnet.market.integration.js --exit --timeout 600000",
    "test:playnet-beacon": "FABRIC_BITCOIN_SKIP_PLAYNET_PEER=1 FABRIC_PLAYNET_BEACON=1 mocha tests/playnet.beacon.federation.integration.js --exit --timeout 400000",
    "playnet:mesh": "node scripts/playnet-regtest-mesh-launch.js",
    "playnet:mesh:open": "node scripts/playnet-regtest-mesh-launch.js --open",
    "test:e2e-webrtc": "node scripts/verify-webrtc-chat-e2e.js",
    "test:hub-webrtc": "mocha tests/hub.webrtc.rpc.test.js",
    "test:document-network": "mocha tests/hub.document.network.e2e.test.js --exit --timeout 180000",
    "test:fabric-epic": "mocha tests/hub.fabric.epic.e2e.test.js --exit --timeout 240000",
    "test:webrtc": "npm run test:bridge && npm run test:hub-webrtc",
    "todo": "npm run report:todo && cat reports/TODO.txt"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FabricLabs/hub.fabric.pub.git"
  },
  "keywords": [
    "fabric",
    "p2p",
    "bitcoin",
    "blockchain",
    "sidechain"
  ],
  "author": "Fabric Labs",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/FabricLabs/hub.fabric.pub/issues"
  },
  "homepage": "https://github.com/FabricLabs/hub.fabric.pub#readme",
  "dependencies": {
    "@babel/preset-env": "=7.26.7",
    "@babel/preset-react": "=7.26.3",
    "@babel/register": "=7.25.9",
    "@fabric/core": "FabricLabs/fabric#feature/v0.1.0-RC1",
    "@fabric/http": "FabricLabs/fabric-http#feature/v0.1.0-RC1",
    "@noble/curves": "=2.0.1",
    "@noble/hashes": "=2.0.1",
    "@types/react": "=18.3.18",
    "bip32": "=4.0.0",
    "bitcoinjs-lib": "=6.1.7",
    "bs58check": "=3.0.1",
    "cross-fetch": "=4.1.0",
    "fast-json-patch": "=3.1.1",
    "graphviz-wasm": "=3.0.2",
    "html5-qrcode": "=2.3.8",
    "isomorphic-ws": "=4.0.1",
    "jquery": "=3.7.1",
    "jsdoc-to-markdown": "=8.0.0",
    "jsdom": "=28.1.0",
    "lodash.merge": "=4.6.2",
    "mocha": "=10.8.2",
    "nodemailer": "=8.0.5",
    "path-browserify": "=1.0.1",
    "process": "=0.11.10",
    "qrcode": "=1.5.4",
    "react": "=18.2.0",
    "react-dom": "=18.2.0",
    "react-redux": "=8.1.0",
    "react-router-dom": "=6.30.3",
    "react-simple-star-rating": "=5.1.7",
    "react-textarea-autosize": "=8.5.7",
    "react-toastify": "=10.0.5",
    "redux": "=4.2.1",
    "redux-thunk": "=2.4.2",
    "semantic-ui-react": "=2.1.5",
    "stream-browserify": "=3.0.0",
    "tiny-secp256k1": "=2.2.4",
    "webpack": "=5.105.4",
    "ws": "=8.18.0"
  },
  "devDependencies": {
    "babel-loader": "=9.1.3",
    "bip39": "=3.1.0",
    "browserify-fs": "=1.0.0",
    "buffer": "=6.0.3",
    "c8": "=7.11.3",
    "crypto-browserify": "=3.12.1",
    "css-loader": "=6.10.0",
    "ecpair": "=2.1.0",
    "electron": "=36.3.2",
    "electron-builder": "=24.13.3",
    "extend": "=3.0.2",
    "style-loader": "=3.3.4",
    "vm-browserify": "=1.1.2",
    "webpack-bundle-analyzer": "=4.10.2",
    "webpack-cli": "=5.1.4",
    "webpack-dev-server": "=5.2.2"
  },
  "overrides": {
    "elliptic": "npm:@soatok/elliptic-to-noble@^9999.0.0",
    "serialize-javascript": "7.0.5"
  },
  "c8": {
    "exclude": [
      "assets",
      "tests",
      "stores"
    ],
    "report-dir": "./reports/coverage",
    "temp-dir": "./reports/c8"
  },
  "build": {
    "appId": "pub.fabric.hub",
    "productName": "Fabric Hub",
    "copyright": "Copyright © Fabric Labs",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "assets/**/*",
      "scripts/desktop.js",
      "scripts/desktop-preload.js",
      "scripts/desktopHubProbe.js",
      "scripts/hub.js",
      "services/**/*",
      "functions/**/*",
      "types/**/*",
      "routes/**/*",
      "settings/**/*",
      "shims/**/*",
      "package.json",
      "node_modules/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!stores/**",
      "!tests/**",
      "!docs/**",
      "!coverage/**",
      "!reports/**",
      "!extension/**",
      "!libraries/**"
    ],
    "extraMetadata": {
      "main": "scripts/desktop.js"
    },
    "protocols": [
      {
        "name": "Fabric Hub",
        "schemes": [
          "fabric"
        ]
      },
      {
        "name": "Fabric Hub Bitcoin",
        "schemes": [
          "bitcoin"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
